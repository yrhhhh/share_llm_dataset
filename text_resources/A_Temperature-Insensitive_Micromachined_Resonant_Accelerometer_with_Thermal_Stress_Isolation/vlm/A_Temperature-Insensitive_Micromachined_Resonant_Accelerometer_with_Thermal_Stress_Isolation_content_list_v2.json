                "html": "<table><tr><td>Serial number</td><td>TDC1 (Hz/°C)</td><td>TDC2 (Hz/°C)</td><td>SF (Hz/g)</td><td>Differential TDC (μg/°C)</td></tr><tr><td>M1</td><td>-0.5907</td><td>-0.5873</td><td>244</td><td>-13.9</td></tr><tr><td>M2</td><td>-0.5897</td><td>-0.5924</td><td>256</td><td>10.5</td></tr><tr><td>M3</td><td>-0.5862</td><td>-0.5795</td><td>256</td><td>-26.2</td></tr></table>",
                "table_type": "simple_table",
