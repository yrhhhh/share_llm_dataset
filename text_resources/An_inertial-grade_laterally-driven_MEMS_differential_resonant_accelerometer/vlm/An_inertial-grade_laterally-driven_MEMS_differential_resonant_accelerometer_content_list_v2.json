            "bbox": [
                305,
                151,
                691,
                166
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Seoul National University, Korea, kchun@mintlab.snu.ac.kr "
                    }
                ]
            },
            "bbox": [
                297,
