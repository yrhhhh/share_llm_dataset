                "title_content": [
                    {
                        "type": "text",
                        "content": "An Inertial-grade laterally-driven MEMS Differential Resonant Accelerometer "
                    }
                ],
                "level": 1
            },
            "bbox": [
                117,
                66,
                879,
                112
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Seonho Seok, Hak Kim, and Kukjin Chun "
                    }
                ]
            },
            "bbox": [
