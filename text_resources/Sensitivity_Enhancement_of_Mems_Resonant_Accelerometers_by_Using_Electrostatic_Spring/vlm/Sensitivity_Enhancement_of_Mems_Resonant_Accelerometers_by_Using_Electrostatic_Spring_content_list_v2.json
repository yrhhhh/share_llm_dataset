                483
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "where the  "
                    },
                    {
                        "type": "equation_inline",
                        "content": "w_{T}"
                    },
                    {
                        "type": "text",
                        "content": " is the resonant frequency of the resonators,  "
                    },
                    {
                        "type": "equation_inline",
                        "content": "A_{cc}"
                    },
                    {
                        "type": "text",
                        "content": " is the input of acceleration,  "
                    },
                    {
                        "type": "equation_inline",
                        "content": "S_{0}"
                    },
                    {
                        "type": "text",
                        "content": " is the sensitivity without sensitivity enhancing effect, which is  "
                    },
                    {
                        "type": "equation_inline",
                        "content": "V_{BP} = 0"
                    },
                    {
                        "type": "text",
                        "content": ",  "
                    },
                    {
                        "type": "equation_inline",
                        "content": "k_{e}"
                    },
                    {
                        "type": "text",
                        "content": " is the effective of the electrostatic spring and  "
                    },
                    {
                        "type": "equation_inline",
                        "content": "k_{eff}"
                    },
                    {
                        "type": "text",
                        "content": " is the effective mechanical spring stiffness on proof mass. The sensitivity can be enhanced by increasing  "
                    },
                    {
                        "type": "equation_inline",
                        "content": "k_{e}"
                    },
                    {
                        "type": "text",
                        "content": " using sensitivity enhancing structure. "
                    }
                ]
            },
            "bbox": [
                66,
                497,
