            "content": {
                "title_content": [
                    {
                        "type": "text",
                        "content": "A CMOS Readout Circuit for Silicon Resonant Accelerometer with 32-ppb bias stability "
                    }
                ],
                "level": 1
            },
            "bbox": [
                84,
                61,
                916,
                85
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Lin He, Yong Ping Xu and Moorthi Palaniapan "
                    }
                ]
            },
            "bbox": [
                318,
                97,
                684,
                115
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Department of Electrical and Computer Engineering, National University of Singapore, 4 Engineering Dr 3, 117576 Singapore E-mail: Lin_he00@nus.edu.sg, yongpingxu@nus.edu.sg, elemp@nus.edu.sg "
                    }
                ]
